// Schemat przepływu danych pracy. Render: dot -Tpng pipeline.dot -o fig_00_pipeline.png
digraph pipeline {
  rankdir=TB;
  bgcolor="white";
  node [shape=box, style="rounded,filled", fontname="DejaVu Sans", fontsize=11, margin="0.18,0.10"];
  edge [fontname="DejaVu Sans", fontsize=9, color="#555555"];

  // --- Źródła CRIS ---
  subgraph cluster_src {
    label="Źródła danych: 4 instancje Omega-PSIR (CRIS)";
    labelloc="t"; fontname="DejaVu Sans"; fontsize=11; color="#9bb7d4"; style="rounded";
    UPWR [label="UPWr", fillcolor="#dceaf5"];
    SGGW [label="SGGW", fillcolor="#dceaf5"];
    URK  [label="URK",  fillcolor="#dceaf5"];
    UWM  [label="UWM",  fillcolor="#dceaf5"];
  }

  // --- Scraping Python ---
  SCRAPE [label="Scraper Python (Playwright)\nETAP 1: paginator → author_id\nETAP 2: profile + metryki", fillcolor="#fde9c9"];
  PUBS   [label="Scraper list publikacji\n(scrape_publications.py)\nrok + punkty per pozycja", fillcolor="#fde9c9"];

  RAW [label="Surowe CSV per uczelnia\n(Dane/raw)", fillcolor="#eeeeee"];

  // --- Pipeline R ---
  CLEAN [label="02 Czyszczenie (R)\nstandaryzacja, deduplikacja\n→ 462 osoby", fillcolor="#d8ecd8"];
  MATCH [label="03 Matching OpenAlex (R)\nROR + Jaro-Winkler ≥ 0,85\n→ 79,4% dopasowania", fillcolor="#d8ecd8"];
  WORKS [label="04 Works OpenAlex (R)\nFWCI, cytowania, współautorzy", fillcolor="#d8ecd8"];
  FEAT  [label="05 Feature engineering (R)", fillcolor="#d8ecd8"];

  OA [label="OpenAlex API", shape=cylinder, fillcolor="#e7d9f0"];

  MASTER [label="Master dataset\nprofiles_features.csv (462 × 30)", fillcolor="#cfe2cf", penwidth=2];
  PUBYEARS [label="pub_years.csv\n(491 osób, 100% próby)", fillcolor="#cfe2cf", penwidth=2];

  // --- Warstwy analityczne ---
  ANALYS [label="Warstwy analityczne (R)\n06 EDA/ANOVA  ·  07 klastrowanie/PCA\n08 modele RF/XGBoost  ·  09 sieci współautorstwa", fillcolor="#f6d7d7"];
  DYN [label="Dynamika rozwoju (R)\n11 OpenAlex  ·  12 Omega-PSIR", fillcolor="#f6d7d7"];

  // --- Krawędzie ---
  UPWR -> SCRAPE; SGGW -> SCRAPE; URK -> SCRAPE; UWM -> SCRAPE;
  UPWR -> PUBS [style=dashed]; SGGW -> PUBS [style=dashed]; URK -> PUBS [style=dashed]; UWM -> PUBS [style=dashed];

  SCRAPE -> RAW -> CLEAN -> MATCH -> WORKS -> FEAT -> MASTER;
  OA -> MATCH [dir=both, style=dashed, label="zapytania"];
  OA -> WORKS [dir=both, style=dashed];
  MASTER -> ANALYS;

  PUBS -> PUBYEARS -> DYN;
  MASTER -> DYN [style=dashed, label="denominatory / match"];
}
